{
  "name": "x21-contracts",
  "version": "0.1.0",
  "description": "X21 — bonding curve token",
  "repository": {
    "type": "git",
    "url": "https://github.com/X21coin/X21.git"
  },
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
